# Generate a long, random value for production; never commit your actual .env file.
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Small tolerance for browser/server clock drift during local development.
GOOGLE_CLOCK_SKEW_SECONDS=30
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Comma-separated frontend origins. Add your deployed URL in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
